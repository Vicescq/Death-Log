    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.1.5",
    "alasql": "^4.17.3",
    "daisyui": "^5.5.14",
    "dexie": "^4.0.11",
    "dotenv": "^16.5.0",
    "echarts": "^6.1.0",
    "nanoid": "^5.1.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-echarts-library": "^1.4.0",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.71.1",
    "react-router": "^7.6.0",
    "react-virtuoso": "^4.18.1",
    "tailwindcss": "^4.1.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
